[DEFAULT]
host = https://default
token = default

[query]
host = https://query/?o=1234
token = query

[nohost]
token = query

# Duplicate entry for https://foo
[foo1]
host = https://foo
token = foo1

[acc]
host = https://accounts.cloud.databricks.com
account_id = abc

# Duplicate entry for https://foo
[foo2]
