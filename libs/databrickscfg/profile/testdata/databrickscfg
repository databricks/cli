[spog-ws1]
host = https://spog.databricks.com
workspace_id = 111
token = spog-ws1

[spog-ws2]
host = https://spog.databricks.com
workspace_id = 222
token = spog-ws2

# SPOG profiles with same host and same workspace_id (ambiguous)
[spog-dup1]
host = https://spog-dup.databricks.com
workspace_id = 333
token = spog-dup1

[spog-dup2]
host = https://spog-dup.databricks.com
