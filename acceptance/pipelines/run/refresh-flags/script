print_requests() {
    print_requests.py //pipelines
}

trace $CLI pipelines deploy
rm out.requests.txt

title "Running pipeline with --refresh flag and specific tables"
trace $CLI pipelines run --refresh table1,table2
trace print_requests

title "Running pipeline with --full-refresh-all flag"
trace $CLI pipelines run --full-refresh-all
trace print_requests

title "Running pipeline with --full-refresh flag and specific tables"
trace $CLI pipelines run --full-refresh table1,table2
trace print_requests

title "Running pipeline with --full-refresh flag and --refresh flag"
trace $CLI pipelines run --full-refresh table1,table2 --refresh table3,table4
trace print_requests
