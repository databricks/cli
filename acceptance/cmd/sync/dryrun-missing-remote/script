# Prevent Git Bash on Windows from converting the /Users/... paths into Windows
# paths (e.g. C:/Program Files/Git/Users/...) before the CLI sees them.
export MSYS_NO_PATHCONV=1

mkdir .git
cat > .gitignore << EOF
.databricks/
script
test.toml
output.txt
out.requests.txt
repls.json
EOF

# Use an ephemeral remote directory so concurrent test runs do not interfere.
remote_dir="/Users/$CURRENT_USER_NAME/missing-dir-$UNIQUE_NAME"

cleanup() {
  $CLI workspace delete --recursive "$remote_dir" 2>/dev/null || true
  rm -rf .git .gitignore .databricks out.requests.txt
}
trap cleanup EXIT

# A dry run must not create the missing remote dir or upload anything.
# Note: output line starting with Action lists files in non-deterministic order so we filter it out
trace $CLI sync . "$remote_dir" --dry-run | grep -v "^Action" | sort

trace print_requests.py --sort //api/ | jq '{method, path}'

trace $CLI sync . "$remote_dir" | grep -v "^Action" | sort

trace print_requests.py --sort //api/ | jq '{method, path}'
