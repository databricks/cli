$CLI workspace import "/test-dir/New Notebook 2026-05-04 13:54:24.py" --file notebook.py --format AUTO --language PYTHON

mkdir -p "$TEST_TMP_DIR/export"

# The notebook name contains ':', which is illegal in a local filename on Windows
# but legal on Linux/macOS. export-dir skips it with a warning on Windows and
# exports it normally elsewhere (databricks/cli#5171). The output therefore
# differs per OS, so capture it in out.<goos>.txt.
case "$OSTYPE" in
    msys | cygwin | win32) goos=windows ;;
    darwin*) goos=darwin ;;
    *) goos=linux ;;
esac

title "export-dir output is OS-specific; see out.<goos>.txt\n"
trace $CLI workspace export-dir /test-dir "$TEST_TMP_DIR/export" >"out.$goos.txt" 2>&1
