if [ "$DATABRICKS_BUNDLE_ENGINE" == "direct" ]; then
    # In terraform schema, the tasks array is 'task' (singular); in SDK it's 'tasks'.
    # python_wheel_task[0] is left as-is: [0] on a struct is a no-op in structaccess.
    update_file.py databricks.yml '.task[0].' '.tasks[0].'
fi

touch hello.whl
trace $CLI bundle deploy
trace print_telemetry_bool_values > out.telemetry.$DATABRICKS_BUNDLE_ENGINE.txt
rm out.requests.txt hello.whl
