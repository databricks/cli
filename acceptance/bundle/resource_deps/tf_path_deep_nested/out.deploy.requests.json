{
  "method": "POST",
  "path": "/api/2.2/jobs/create",
  "body": {
    "deployment": {
      "kind": "BUNDLE",
      "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
    },
    "edit_mode": "UI_LOCKED",
    "format": "MULTI_TASK",
    "max_concurrent_runs": 1,
    "name": "source",
    "queue": {
      "enabled": true
    },
    "tasks": [
      {
        "for_each_task": {
          "inputs": "[\"a\"]",
          "task": {
            "libraries": [
              {
                "whl": "/path/to/wheel.whl"
              }
            ],
            "notebook_task": {
              "notebook_path": "/Workspace/notebook"
            },
            "task_key": "inner"
          }
        },
        "task_key": "outer"
      }
    ]
  }
}
{
  "method": "POST",
  "path": "/api/2.2/jobs/create",
  "body": {
    "deployment": {
      "kind": "BUNDLE",
      "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
    },
    "edit_mode": "UI_LOCKED",
    "format": "MULTI_TASK",
    "max_concurrent_runs": 1,
    "name": "/path/to/wheel.whl",
    "queue": {
      "enabled": true
    }
  }
}
