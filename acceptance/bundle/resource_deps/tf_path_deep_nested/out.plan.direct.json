{
  "plan_version": 2,
  "cli_version": "[DEV_VERSION]",
  "plan": {
    "resources.jobs.dst": {
      "depends_on": [
        {
          "node": "resources.jobs.src",
          "label": "${resources.jobs.src.trigger[0].file_arrival[0].url}"
        }
      ],
      "action": "create",
      "new_state": {
        "value": {
          "deployment": {
            "kind": "BUNDLE",
            "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
          },
          "edit_mode": "UI_LOCKED",
          "format": "MULTI_TASK",
          "max_concurrent_runs": 1,
          "name": "abfss://container@account.dfs.core.windows.net/path",
          "queue": {
            "enabled": true
          }
        }
      }
    },
    "resources.jobs.src": {
      "action": "create",
      "new_state": {
        "value": {
          "deployment": {
            "kind": "BUNDLE",
            "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
          },
          "edit_mode": "UI_LOCKED",
          "format": "MULTI_TASK",
          "max_concurrent_runs": 1,
          "name": "source",
          "queue": {
            "enabled": true
          },
          "trigger": {
            "file_arrival": {
              "url": "abfss://container@account.dfs.core.windows.net/path"
            },
            "pause_status": "UNPAUSED"
          }
        }
      }
    }
  }
}
