{
  "plan_version": 2,
  "cli_version": "[DEV_VERSION]",
  "plan": {
    "resources.jobs.dst": {
      "depends_on": [
        {
          "node": "resources.jobs.src",
          "label": "${resources.jobs.src.schedule[0].quartz_cron_expression}"
        }
      ],
      "action": "create",
      "new_state": {
        "value": {
          "deployment": {
            "kind": "BUNDLE",
            "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
          },
          "edit_mode": "UI_LOCKED",
          "format": "MULTI_TASK",
          "max_concurrent_runs": 1,
          "name": "0 0 * * * ?",
          "queue": {
            "enabled": true
          }
        }
      }
    },
    "resources.jobs.src": {
      "action": "create",
      "new_state": {
        "value": {
          "deployment": {
            "kind": "BUNDLE",
            "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
          },
          "edit_mode": "UI_LOCKED",
          "format": "MULTI_TASK",
          "max_concurrent_runs": 1,
          "name": "source",
          "queue": {
            "enabled": true
          },
          "schedule": {
            "pause_status": "UNPAUSED",
            "quartz_cron_expression": "0 0 * * * ?",
            "timezone_id": "UTC"
          }
        }
      }
    }
  }
}
