envsubst < databricks.yml.tmpl > databricks.yml

# Deploy the ingestion pipeline. It fails because the connection name is
# intentionally invalid, but the POST /api/2.0/pipelines request is sent and
# recorded first. The key assertion: edition and channel are absent from the
# request body — DABs must not inject them for ingestion pipelines.
trace errcode $CLI bundle deploy

# Show what was sent to the API. edition and channel must be null (absent).
trace jq -s '.[] | select(.path=="/api/2.0/pipelines" and .method=="POST") | .body | {name, edition, channel}' out.requests.txt
rm out.requests.txt
