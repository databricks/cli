envsubst < databricks.yml.tmpl > databricks.yml

cleanup() {
   # The primary read-write endpoint cannot be deleted independently of its
   # branch, so destroy by cascading from the project.
   $CLI postgres delete-project "projects/test-pg-proj-${UNIQUE_NAME}" 2>/dev/null || true
   rm -f out.requests.txt
}
trap cleanup EXIT

trace $CLI bundle validate

rm -f out.requests.txt
trace $CLI bundle deploy

# The implicit primary endpoint inherits suspend_timeout_duration from the
# project default (300s). After deploy with replace_existing=true, the
# bundle's spec must be applied: 600s.
trace $CLI postgres get-endpoint "projects/test-pg-proj-${UNIQUE_NAME}/branches/develop/endpoints/primary" | jq 'del(.create_time, .update_time)'

trace print_requests.py --keep --get '//postgres' '^//workspace-files/' '^//workspace/' '^//telemetry-ext' '^//operations/' > out.requests.$DATABRICKS_BUNDLE_ENGINE.json
