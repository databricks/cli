{
  "method": "POST",
  "path": "/api/2.0/postgres/projects",
  "q": {
    "project_id": "test-pg-proj-[UNIQUE_NAME]"
  },
  "body": {
    "spec": {
      "display_name": "Test Project for Database Update",
      "history_retention_duration": "604800s",
      "pg_version": 16
    }
  }
}
{
  "method": "POST",
  "path": "/api/2.0/postgres/projects/test-pg-proj-[UNIQUE_NAME]/branches",
  "q": {
    "branch_id": "main"
  },
  "body": {
    "spec": {
      "no_expiry": true
    }
  }
}
{
  "method": "POST",
  "path": "/api/2.0/postgres/projects/test-pg-proj-[UNIQUE_NAME]/branches/main/databases",
  "q": {
    "database_id": "my-database"
  },
  "body": {
    "spec": {
      "postgres_database": "initial_db_name",
      "role": "projects/test-pg-proj-[UNIQUE_NAME]/branches/main/roles/[USERNAME]"
    }
  }
}
