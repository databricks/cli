{
  "plan_version": 2,
  "cli_version": "[DEV_VERSION]",
  "lineage": "[UUID]",
  "serial": 1,
  "plan": {
    "resources.pipelines.foo": {
      "action": "skip",
      "remote_state": {
        "channel": "CURRENT",
        "creator_user_name": "[USERNAME]",
        "deployment": {
          "kind": "BUNDLE",
          "metadata_file_path": "/Workspace/Users/[USERNAME]/.bundle/test-bundle/default/state/metadata.json"
        },
        "edition": "ADVANCED",
        "effective_publishing_mode": "DEFAULT_PUBLISHING_MODE",
        "id": "[UUID]",
        "last_modified": [UNIX_TIME_MILLIS],
        "name": "foo",
        "pipeline_id": "[UUID]",
        "run_as_user_name": "[USERNAME]",
        "state": "IDLE",
        "storage": "dbfs:/pipelines/[UUID]"
      },
      "changes": {
        "storage": {
          "action": "skip",
          "reason": "backend_default",
          "remote": "dbfs:/pipelines/[UUID]"
        }
      }
    },
    "resources.pipelines.foo.permissions": {
      "depends_on": [
        {
          "node": "resources.pipelines.foo",
          "label": "${resources.pipelines.foo.id}"
        }
      ],
      "action": "update",
      "new_state": {
        "value": {
          "object_id": "/pipelines/[UUID]",
          "__embed__": [
            {
              "level": "CAN_MANAGE",
              "user_name": "viewer@example.com"
            },
            {
              "level": "IS_OWNER",
              "user_name": "[USERNAME]"
            }
          ]
        }
      },
      "remote_state": {
        "object_id": "/pipelines/[UUID]",
        "__embed__": [
          {
            "level": "CAN_VIEW",
            "user_name": "viewer@example.com"
          },
          {
            "level": "IS_OWNER",
            "user_name": "[USERNAME]"
          }
        ]
      },
      "changes": {
        "[user_name='viewer@example.com'].level": {
          "action": "update",
          "old": "CAN_VIEW",
          "new": "CAN_MANAGE",
          "remote": "CAN_VIEW"
        }
      }
    }
  }
}
