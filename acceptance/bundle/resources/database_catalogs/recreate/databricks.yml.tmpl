bundle:
  name: recreate-lakebase-catalog-$UNIQUE_NAME

sync:
  paths: []

resources:
  database_instances:
    my_instance:
      name: test-db-cat-rc-$UNIQUE_NAME
      capacity: CU_1
  database_catalogs:
    my_catalog:
      database_instance_name: ${resources.database_instances.my_instance.name}
      database_name: db_initial
      name: cat_$UNIQUE_NAME
      create_database_if_not_exists: true
