bundle:
  name: deploy-postgres-replace-branch-$UNIQUE_NAME

sync:
  paths: []

resources:
  postgres_projects:
    my_project:
      project_id: test-pg-proj-$UNIQUE_NAME
      display_name: "Replace existing branch test"
      pg_version: 16
      history_retention_duration: "604800s"

  # Take over the implicitly-created production branch with replace_existing.
  # is_protected is left at its default (false) so that bundle destroy can
  # delete the branch at the end of the test. no_expiry is sent in the spec
  # to demonstrate the create request goes through; the field is input-only
  # and not surfaced in get-branch.
  postgres_branches:
    production:
      parent: ${resources.postgres_projects.my_project.id}
      branch_id: production
      replace_existing: true
      no_expiry: true
