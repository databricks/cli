normalize_grants() {
    jq --sort-keys --arg current "$CURRENT_USER_NAME" '
        .privilege_assignments |= sort_by((.principal != $current), .principal) |
        (.privilege_assignments[]?.privileges |= sort)
    '
}

add_repl.py "$CURRENT_USER_NAME" CURRENT_USER_NAME
envsubst < databricks.yml.tmpl > databricks.yml

cleanup() {
    trace errcode $CLI bundle destroy --auto-approve
    rm -f out.requests.txt
}
trap cleanup EXIT

trace $CLI bundle deploy
trace $CLI grants get schema main.schema_remove_principal_$UNIQUE_NAME | normalize_grants

$CLI grants get schema main.schema_remove_principal_$UNIQUE_NAME |
    normalize_grants |
    gron.py |
    contains.py \
        ".principal = \"$CURRENT_USER_NAME\";" \
        '.principal = "deco-test-user@databricks.com";' > /dev/null

grep -v 'TO_REMOVE' databricks.yml > tmp.yml && mv tmp.yml databricks.yml

trace $CLI bundle deploy
trace $CLI grants get schema main.schema_remove_principal_$UNIQUE_NAME | normalize_grants

$CLI grants get schema main.schema_remove_principal_$UNIQUE_NAME |
    normalize_grants |
    gron.py |
    contains.py \
        ".principal = \"$CURRENT_USER_NAME\";" \
        '!.principal = "deco-test-user@databricks.com";' > /dev/null

trace $CLI bundle plan
