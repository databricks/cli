mkdir -p .databricks/bundle/default/terraform
echo '{"serial": 1, "lineage": "test-lineage"}' > .databricks/bundle/default/terraform/terraform.tfstate

title 'Default env var matches state: no warning\n'
unset DATABRICKS_BUNDLE_ENGINE
trace DATABRICKS_BUNDLE_ENGINE_DEFAULT=terraform $CLI bundle debug states

title 'Default env var does not match state: state wins silently\n'
unset DATABRICKS_BUNDLE_ENGINE
trace DATABRICKS_BUNDLE_ENGINE_DEFAULT=direct $CLI bundle debug states

title 'DATABRICKS_BUNDLE_ENGINE overrides default\n'
trace DATABRICKS_BUNDLE_ENGINE=terraform DATABRICKS_BUNDLE_ENGINE_DEFAULT=direct $CLI bundle debug states

title 'Invalid default env var: error expected\n'
export DATABRICKS_BUNDLE_ENGINE_DEFAULT=bla
unset DATABRICKS_BUNDLE_ENGINE
trace musterr $CLI bundle debug states
