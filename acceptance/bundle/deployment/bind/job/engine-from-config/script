# Demonstrate that bind ignores bundle.engine config and existing state.
#
# bundle.engine is set to "direct" in databricks.yml.
# DATABRICKS_BUNDLE_ENGINE is not set in the environment.
#
# Expected: both deploy and bind should use direct engine (from config).
# Actual bug: deploy uses direct (correct), bind defaults to terraform
# because it only reads DATABRICKS_BUNDLE_ENGINE env var via engine.FromEnv().

job_id=$(trace $CLI jobs create --json '{"name": "My Job"}' | jq -r '.job_id')

# Deploy uses direct engine (reads bundle.engine from config).
trace $CLI bundle deploy

echo "=== State files after deploy ==="
find.py 'resources\.json|terraform\.tfstate$'

# Bind should also use direct engine, but defaults to terraform
# because it only reads DATABRICKS_BUNDLE_ENGINE env var.
trace $CLI bundle deployment bind job_1 $job_id --auto-approve

echo "=== State files after bind ==="
find.py 'resources\.json|terraform\.tfstate$'
