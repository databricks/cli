VOLUME_NAME="volume-$(uuid)"
SCHEMA_NAME="test-schema-$(uuid)"
if [ -z "$CLOUD_ENV" ]; then
    VOLUME_NAME="volume-6260d50f-e8ff-4905-8f28-812345678903"   # use hard-coded uuid when running locally
    SCHEMA_NAME="test-schema-6260d50f-e8ff-4905-8f28-812345678903"
fi
export VOLUME_NAME
export SCHEMA_NAME

echo "$VOLUME_NAME:VOLUME_NAME" >> ACC_REPLS
echo "$SCHEMA_NAME:SCHEMA_NAME" >> ACC_REPLS

export CATALOG_NAME="main"
envsubst < databricks.yml.tmpl > databricks.yml

VOLUME_TYPE="MANAGED"

trace $CLI schemas create "${SCHEMA_NAME}" ${CATALOG_NAME} | jq '{full_name, catalog_name}'

title "Create a pre-defined volume:"
trace $CLI volumes create "${CATALOG_NAME}" "${SCHEMA_NAME}" "${VOLUME_NAME}" "${VOLUME_TYPE}" | jq '{catalog_name, full_name, schema_name, volume_type}'
trace $CLI volumes read "main.$SCHEMA_NAME.$VOLUME_NAME" | jq '{catalog_name, full_name, schema_name, volume_type}'

cleanupRemoveVolume() {
    $CLI volumes delete "main.$SCHEMA_NAME.$VOLUME_NAME"
}
trap cleanupRemoveVolume EXIT

trace $CLI bundle deployment bind volume1 "main.$SCHEMA_NAME.$VOLUME_NAME" --auto-approve
trace $CLI volumes read "main.$SCHEMA_NAME.$VOLUME_NAME" | jq '{catalog_name, full_name, schema_name, volume_type}'

trace print_state.py > out.state_after_bind.$DATABRICKS_BUNDLE_ENGINE.json

trace $CLI bundle plan -o json > out.plan.$DATABRICKS_BUNDLE_ENGINE.json

trace $CLI bundle deploy

trace $CLI volumes read "main.$SCHEMA_NAME.$VOLUME_NAME" | jq '{catalog_name, full_name, schema_name, volume_type}'

trace $CLI bundle deployment unbind volume1

trace $CLI bundle destroy --auto-approve

trace $CLI volumes read "main.$SCHEMA_NAME.$VOLUME_NAME" | jq '{catalog_name, full_name, schema_name, volume_type}'
