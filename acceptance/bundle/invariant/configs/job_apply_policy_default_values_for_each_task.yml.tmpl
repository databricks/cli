bundle:
  name: test-bundle-$UNIQUE_NAME

resources:
  jobs:
    foo:
      name: test-job-$UNIQUE_NAME
      tasks:
        - task_key: main
          for_each_task:
            inputs: "[1]"
            task:
              task_key: inner
              notebook_task:
                notebook_path: /Shared/notebook
              new_cluster:
                spark_version: $DEFAULT_SPARK_VERSION
                instance_pool_id: $TEST_INSTANCE_POOL_ID
                num_workers: 1
                apply_policy_default_values: true
