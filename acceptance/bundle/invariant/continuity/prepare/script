
cp -r "$TESTDIR/../../data/." . &> LOG.cp

INIT_SCRIPT="$TESTDIR/../../configs/$INPUT_CONFIG-init.sh"
if [ -f "$INIT_SCRIPT" ]; then
    source "$INIT_SCRIPT" &> LOG.init
fi

envsubst < "$TESTDIR/../../configs/$INPUT_CONFIG" > databricks.yml

DATABRICKS_BUNDLE_ENGINE=direct trace $CLI bundle deploy &> LOG.deploy

mkdir -p "$TESTDIR/../$CONTINUITY_VERSION"
cp .databricks/bundle/default/resources.json "$TESTDIR/../$CONTINUITY_VERSION/${INPUT_CONFIG}.state.json"
