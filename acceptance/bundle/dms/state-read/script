# Seed a job resource into DMS for a synthetic deployment using a raw API call,
# point local state at that deployment (the lineage is the deployment id), and
# verify `bundle summary` resolves the job id from DMS ListResources rather than
# from the local resources.json (which intentionally carries no resource state).

title "Seed a job resource into DMS for a synthetic deployment"
trace $CLI api post '/api/2.0/bundle/deployments/synthetic-dep/versions/1/operations' --json '{"resource_key":"jobs.foo","resource_id":"9999","action_type":"OPERATION_ACTION_TYPE_CREATE","status":"OPERATION_STATUS_SUCCEEDED","state":{"name":"foo"}}'

title "Place the pointer state on the workspace (lineage == deployment id, no resource state); the CLI pulls it before reading"
trace $CLI api post "/api/2.0/workspace-files/import-file/Workspace/Users/$CURRENT_USER_NAME/.bundle/dms-state-read/default/state/resources.json?overwrite=true" --json '{"state_version":2,"lineage":"synthetic-dep","serial":1,"state":{}}'

title "bundle summary resolves jobs.foo id (9999) from DMS ListResources"
trace $CLI bundle summary
trace print_requests.py --get //api/2.0/bundle/deployments/synthetic-dep/resources
